{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortImports": {
    "enabled": true,
    "groups": [
      ["builtin", "external"],
      ["internal", "subpath"],
      ["parent", "sibling", "index"]
    ],
    "newlinesBetween": false,
    "order": "asc",
    "ignoreCase": true
  }
}
