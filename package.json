{
  "name": "lathe",
  "version": "0.0.0",
  "private": true,
  "description": "Lathe — sequential overnight executor of human-written specs.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --reporter=append-only build",
    "typecheck": "pnpm -r --reporter=append-only typecheck",
    "check": "pnpm -r --reporter=append-only lint && pnpm -r --reporter=append-only typecheck",
    "test": "pnpm -r --reporter=append-only test",
    "lint": "pnpm -r --reporter=append-only lint",
    "fmt": "pnpm -r --reporter=append-only fmt",
    "dev": "pnpm --filter dashboard dev",
    "serve": "pnpm --filter @lathe/cli exec tsx src/index.ts serve",
    "generate": "pnpm --filter @lathe/contract gen"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.2"
}
