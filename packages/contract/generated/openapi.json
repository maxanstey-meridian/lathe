                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "lathe_listRuns",
        "tags": [
          "Lathe"
        ],
        "x-rivet-contract": "lathe",
        "x-rivet-endpoint": "listRuns",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RunSummaryDto"
                  }
                }
              }
            }
          }
