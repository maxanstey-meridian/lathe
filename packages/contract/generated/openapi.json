      "post": {
        "operationId": "lathe_rejectRun",
        "tags": [
          "Lathe"
        ],
        "x-rivet-contract": "lathe",
        "x-rivet-endpoint": "rejectRun",
        "parameters": [
          {
            "name": "runId",
            "in": "path",
