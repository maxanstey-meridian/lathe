  "components": {
    "schemas": {
      "AnswerRunRequest": {
        "type": "object",
        "properties": {
          "answer": {
            "type": "string"
          }
        },
        "required": [
          "answer"
        ]
      },
      "ConfigDto": {
        "type": "object",
        "properties": {
          "models": {
            "$ref": "#/components/schemas/ModelConfigDto"
          },
          "thresholds": {
            "type": "object",
            "properties": {
              "ladderParkAt": {
                "type": "number"
              },
              "ladderRotateAt": {
                "type": "number"
              },
              "maxPasses": {
                "type": "number"
              },
              "turnSteps": {
                "type": "number"
              }
            },
            "required": [
              "ladderParkAt",
              "ladderRotateAt",
              "maxPasses",
              "turnSteps"
            ]
          }
        },
        "required": [
          "models",
          "thresholds"
        ]
      },
      "EnqueueChainRequest": {
        "type": "object",
        "properties": {
          "chainDir": {
            "type": "string"
          }
        },
        "required": [
          "chainDir"
        ]
      },
      "EnqueueRunRequest": {
        "type": "object",
        "properties": {
          "packetPath": {
            "type": "string"
          }
        },
        "required": [
          "packetPath"
        ]
      },
      "ModelConfigDto": {
        "type": "object",
        "properties": {
          "baby": {
            "type": "object",
            "properties": {
              "modelId": {
                "type": "string"
              },
              "baseUrl": {
                "type": "string"
              },
              "contextWindow": {
                "type": "number"
              }
            },
            "required": [
              "modelId",
              "baseUrl",
              "contextWindow"
            ]
          },
          "daddy": {
            "type": "object",
            "properties": {
              "modelId": {
                "type": "string"
              },
              "provider": {
                "type": "string"
              }
            },
            "required": [
              "modelId",
              "provider"
            ]
          },
          "superdaddy": {
            "type": "object",
            "properties": {
              "modelId": {
                "type": "string"
              }
            },
            "required": [
              "modelId"
            ]
          }
        },
        "required": [
          "baby",
          "daddy",
          "superdaddy"
        ]
      },
      "RejectRunRequest": {
        "type": "object",
        "properties": {
          "reason": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "RunDetailDto": {
        "type": "object",
        "properties": {
          "runId": {
            "type": "string"
          },
          "campaignId": {
            "type": "string"
          },
          "packet": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/RunStatus"
          },
          "pass": {
            "type": "number"
          },
          "turn": {
            "type": "number"
          },
          "contextTokens": {
            "type": "number"
          },
          "contextWindow": {
            "type": "number"
          },
          "isChainTip": {
            "type": "boolean"
          },
          "startedAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          },
          "base": {
            "type": "string"
          },
          "branch": {
            "type": "string"
          },
          "worktreePath": {
            "type": "string"
          },
          "parentRunId": {
            "type": [
              "string",
              "null"
            ]
          },
          "expectedSurface": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "lastVerdict": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "runId",
          "campaignId",
          "packet",
          "status",
          "pass",
          "turn",
          "contextTokens",
          "contextWindow",
          "isChainTip",
          "startedAt",
          "updatedAt",
          "base",
          "branch",
          "worktreePath",
          "parentRunId",
          "expectedSurface",
          "lastVerdict"
        ]
      },
      "RunSummaryDto": {
        "type": "object",
        "properties": {
          "runId": {
            "type": "string"
          },
          "campaignId": {
            "type": "string"
          },
          "packet": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/RunStatus"
          },
          "pass": {
            "type": "number"
          },
          "turn": {
            "type": "number"
          },
          "contextTokens": {
            "type": "number"
          },
          "contextWindow": {
            "type": "number"
          },
          "isChainTip": {
            "type": "boolean"
          },
          "startedAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "runId",
          "campaignId",
          "packet",
          "status",
          "pass",
          "turn",
          "contextTokens",
          "contextWindow",
          "isChainTip",
          "startedAt",
          "updatedAt"
        ]
      },
      "RunStatus": {
        "type": "string",
        "enum": [
          "queued",
          "running",
          "paused",
          "converged",
          "accepted",
          "aborted",
          "failed"
        ]
      }
    }
  }
}