{
  "name": "@lathe/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./tail": {
      "types": "./src/interfaces/cli/tail.ts",
      "default": "./dist/interfaces/cli/tail.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "tsx --test tests/*.test.ts",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "fmt": "oxfmt src tests",
    "fmt:check": "oxfmt --check src tests"
  },
  "dependencies": {
    "@lathe/contract": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ink": "^5.1.0",
    "react": "^18.3.1",
    "yaml": "^2.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
