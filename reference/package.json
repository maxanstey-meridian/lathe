{
  "name": "plumb",
  "version": "0.1.0",
  "description": "Meridian v2 — sequential overnight executor of human-written specs. See CONTRACT.md.",
  "type": "module",
  "private": true,
  "bin": {
    "meridian": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc && npm run typecheck:plugin",
    "typecheck": "tsc --noEmit && npm run typecheck:plugin",
    "typecheck:plugin": "tsc --noEmit -p plugin/tsconfig.json",
    "test": "tsc && npm run typecheck:plugin && node --test tests/*.test.mjs",
    "dev": "node --experimental-strip-types src/cli.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.31",
    "typescript": "^5.7.0"
  }
}
